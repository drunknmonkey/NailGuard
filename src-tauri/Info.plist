<?xml version="1.0" encoding="UTF-8"?>
<!--
  Wird von der Tauri-CLI automatisch mit der generierten Info.plist gemerged
  (Datei liegt im src-tauri-Verzeichnis). Ohne NSCameraUsageDescription
  beendet macOS die App beim getUserMedia-Aufruf sofort.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSCameraUsageDescription</key>
    <string>NailGuard nutzt die Kamera lokal, um Hand-zu-Mund-Bewegungen zu erkennen. Es werden keine Bilder gespeichert oder gesendet.</string>
</dict>
</plist>
